<div id="<%= dom_id post %>" class="post">
  <div class="post-content">
    <div class="title">
      <p>
        <%= post.topic.name %>
      </p>
      <div class="actions">
        <% if current_user == @post&.user %>
          <%= link_to "Edit", edit_post_path(@post), class: "button" %>
          <%= button_to "Delete", @post, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this post?" } %>
        <% end %>
      </div>
    </div>
    <h1><%= post.title %></h1>
    <span>
      <%= post.created_at.strftime("%B %d, %Y %H:%M:%S") %>
    </span>
    <p>
      by <%= render "shared/username", user: post.user %>
    </p>
    <%= post.body %>
  </div>
  <% if @replies %>
    <div class="replies">
      <h2 class="label">replies (<%= post.replies.count %>)</h2>
      <% @replies.each do |reply| %>
        <%= render reply %>
      <% end %>
    </div>
    <%= render "shared/pagination", page_param: params[:page], total_pages: @total_pages, path: ->(page:) { post_path(@post, page: page) } %>
  <% end %>
  <button data-controller="toggle" data-action="click->toggle#toggle" data-target=".reply-form">Reply to this post</button>
</div>
