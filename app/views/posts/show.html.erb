<p style="color: green"><%= notice %></p>

<%= render @post %>

<div>
  AAAA<%= current_user %>
  <% if current_user == @post.user %>
    <%= link_to "Edit this post", edit_post_path(@post) %> |
  <% end %>
  <%= link_to "Back to posts", posts_path %>

  <%= button_to "Destroy this post", @post, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this post?" } %>

</div>
