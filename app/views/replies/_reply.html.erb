<li class="reply list-type-none" id="<%= dom_id(reply) %>">
    <div class="flex justify-between">
        <div class="flex flex-col">
            <div class="flex items-start gap-1">
                <%= image_tag reply.user&.personalization_data&.avatar, class: "w-12 h-12" %>
                <div class="flex flex-col">
                    <%= render "shared/username", user: reply.user %>
                    <% if reply.updated_at.to_i > reply.created_at.to_i %>
                        <span class="label text-[var(--secondary)] font-bold text-xs bg-[var(--background-dark)] p-[0.15rem]">edited</span>
                    <% end %>
                    <span class="text-sm"><%= time_ago_in_words(reply&.created_at) %> ago</span>
                </div>
            </div>
        </div>
        <% if current_user.id == reply.user_id %>
        <div class="flex gap-1 items-start">
            <!-- <%= link_to "Edit", edit_reply_path(reply), class: "cta" %> -->
            <%= button_to "X", reply, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "cta-secondary" %>
        </div>
    <% end %>
    </div>
    <%= reply.body %>
<li>