<div id="<%= dom_id topic %>">
  <h1>
    <%= topic.name %>
  </h1>

  <p>
    <%= topic.description %>
  </p>

  <% if @posts&.any? %>
    <ul class="posts">
          <% @posts.each do |post| %>
              <li class="post">
                  <%= link_to post.title, post %>
                  <span class="date"><%= post.created_at.strftime("%B %d, %Y %H:%M:%S") %></span>
                  <p><%= truncate(strip_tags(post.body.to_s), length: 100) %></p>
                  <span class="author">by <%= post.user.username %></span>
              </li>
          <% end %>
      </ul>
      <%= render "shared/pagination", page_param: params[:page], total_pages: @total_pages, path: ->(page:) { topic_path(@topic, page: page) } %>
  <% end %>


</div>
